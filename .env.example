# OpenAI Configuration
OPENAI_API_KEY=sk-your-key-here
MODEL_NAME=gpt-4o
LLM_PROVIDER=openai

# Application
APP_ENV=development
LOG_LEVEL=INFO

# Database (PostgreSQL)
# Para desarrollo local: localhost. Docker Compose sobreescribe con @db:5432.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/clinic_copilot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=clinic_copilot
